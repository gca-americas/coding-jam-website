# --- Auth.js (Google sign-in for build submissions) ---
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=replace-with-32-random-chars

# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:  http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional — only set for non-localhost deployments
# AUTH_URL=https://codingjams.your-domain.com

# --- Storage backend ---
# Default: local JSON file (data/projects.json) in dev, Firestore in production.
# Override explicitly:
#   STORAGE_BACKEND=local      → use data/projects.json (no GCP needed)
#   STORAGE_BACKEND=firestore  → use Firestore (requires GOOGLE_CLOUD_PROJECT + ADC)
# STORAGE_BACKEND=local

# --- Firestore (only used when STORAGE_BACKEND=firestore or in production) ---
# The GCP project that hosts your Firestore database.
# GOOGLE_CLOUD_PROJECT=codingjam-americas

# --- Cloud Storage (screenshot uploads) ---
# Public-read GCS bucket used by /api/upload. The deploy script provisions
# this bucket and grants the Cloud Run runtime SA write access.
# GCS_UPLOADS_BUCKET=codingjam-americas-uploads
